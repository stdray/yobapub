@model PlaybackErrorsViewModel
@{
    ViewData["Title"] = "YobaPub - Ошибки CDN";
}
<header>
  <h1>Ошибки воспроизведения</h1>
  <label><input type="checkbox" id="autoRefresh" checked hx-preserve="true"> Auto 10s</label>
</header>
<div id="page-content"
     hx-get="/admin/playback-errors"
     hx-select="#page-content"
     hx-target="this"
     hx-swap="outerHTML"
     hx-trigger="every 10s [document.getElementById('autoRefresh').checked]">
  <div class="sub-header">
    <span id="status">@Model.TotalEntries записей, @Model.Domains.Length доменов</span>
    <form class="form-inline"
          hx-post="/admin/playback-errors/clear"
          hx-target="#page-content"
          hx-select="#page-content"
          hx-swap="outerHTML"
          hx-confirm="Удалить все записи?">
      <button type="submit" class="danger">Очистить</button>
    </form>
  </div>
  @if (Model.Domains.Length == 0)
  {
    <div class="empty empty-lg">Ошибок нет</div>
  }
  else
  {
    <div class="error-domains">
      @foreach (var d in Model.Domains)
      {
        <details class="domain-group">
          <summary>
            <span class="domain-name">@d.Domain</span>
            <span class="domain-count">@d.TotalErrors ош.</span>
            <span class="domain-devices">@d.Devices.Length устр.</span>
            <span class="domain-ts">@d.LastSeen.FormatShort(UserSettingsStore.Get(User.Identity!.Name!).TimeZoneOffset)</span>
          </summary>
          <table>
            <thead>
              <tr>
                <th>Device</th>
                <th>UserAgent</th>
                <th>Кол-во</th>
                <th>Посл. время</th>
                <th>Посл. ошибка</th>
                <th>IP</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var dev in d.Devices)
              {
                <tr>
                  <td class="dev" title="@dev.DeviceId">@(dev.DeviceId.Length >= 8 ? dev.DeviceId[..8] : dev.DeviceId)</td>
                  <td class="ua">@dev.UserAgent</td>
                  <td>@dev.Count</td>
                  <td class="ts">@dev.LastSeen.FormatShort(UserSettingsStore.Get(User.Identity!.Name!).TimeZoneOffset)</td>
                  <td class="msg">@dev.LastError</td>
                  <td class="ip">@dev.LastIp</td>
                </tr>
              }
            </tbody>
          </table>
        </details>
      }
    </div>
  }
</div>
