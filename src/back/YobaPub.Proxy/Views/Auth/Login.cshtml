@{
    ViewData["Title"] = "YobaPub — Вход";
    ViewData["BodyClass"] = "login";
}
<div class="card">
  <h1>YobaPub Logs</h1>
  <form asp-action="Login" method="post" autocomplete="on">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]">
    <label for="username">Логин</label>
    <input type="text" id="username" name="username" autofocus autocomplete="username" required>
    <label for="password">Пароль</label>
    <input type="password" id="password" name="password" autocomplete="current-password" required>
    <button type="submit">Войти</button>
    @if (ViewData["Error"] != null)
    {
      <div class="error">@ViewData["Error"]</div>
    }
  </form>
</div>
