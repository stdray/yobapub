@model VipViewModel
@{
    ViewData["Title"] = "YobaPub - VIP логины";
}
<div id="page-content">
<header>
  <h1>VIP логины</h1>
  <span id="status">@Model.Logins.Count логинов</span>
</header>
<div class="page-pad">
  <form class="vip-add-form"
        hx-post="/admin/vip/add"
        hx-target="#page-content"
        hx-select="#page-content"
        hx-swap="outerHTML">
    <input type="text" name="login" placeholder="Логин" required class="vip-login-input">
    <button type="submit">Добавить</button>
  </form>
  @if (!string.IsNullOrEmpty(Model.Error))
  {
    <div class="vip-error">@Model.Error</div>
  }
  @if (Model.Logins.Count == 0)
  {
    <div class="empty empty-lg">Нет VIP логинов</div>
  }
  else
  {
    <table>
      <thead>
        <tr>
          <th>Логин</th>
          <th>Добавлен</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var entry in Model.Logins)
        {
          <tr>
            <td>@entry.Login</td>
            <td class="ts">@entry.AddedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
            <td>
              <form class="form-inline"
                    hx-post="/admin/vip/delete"
                    hx-target="#page-content"
                    hx-select="#page-content"
                    hx-swap="outerHTML"
                    hx-confirm="Удалить логин @entry.Login?">
                <input type="hidden" name="login" value="@entry.Login">
                <button type="submit" class="danger vip-delete-btn">&#x2715;</button>
              </form>
            </td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>
</div>
