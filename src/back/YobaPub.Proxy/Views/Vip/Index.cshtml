@model VipViewModel
@{
    ViewData["Title"] = "YobaPub - VIP логины";
}
<div id="page-content">
<header>
  <h1>VIP логины</h1>
  <span id="status">@Model.Logins.Count логинов</span>
</header>
<div style="padding:16px">
  <form hx-post="/admin/vip/add"
        hx-target="#page-content"
        hx-select="#page-content"
        hx-swap="outerHTML"
        style="display:flex;gap:8px;margin-bottom:16px">
    <input type="text" name="login" placeholder="Логин" required
           style="padding:6px 10px;border:1px solid #555;background:#1e1e1e;color:#eee;border-radius:4px;width:250px">
    <button type="submit">Добавить</button>
  </form>
  @if (!string.IsNullOrEmpty(Model.Error))
  {
    <div style="color:#e74c3c;margin-bottom:12px">@Model.Error</div>
  }
  @if (Model.Logins.Count == 0)
  {
    <div class="empty" style="padding:40px">Нет VIP логинов</div>
  }
  else
  {
    <table>
      <thead>
        <tr>
          <th>Логин</th>
          <th>Добавлен</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var entry in Model.Logins)
        {
          <tr>
            <td>@entry.Login</td>
            <td class="ts">@entry.AddedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
            <td>
              <form hx-post="/admin/vip/delete"
                    hx-target="#page-content"
                    hx-select="#page-content"
                    hx-swap="outerHTML"
                    hx-confirm="Удалить логин @entry.Login?"
                    style="margin:0">
                <input type="hidden" name="login" value="@entry.Login">
                <button type="submit" class="danger" style="padding:2px 8px;font-size:12px">✕</button>
              </form>
            </td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>
</div>
