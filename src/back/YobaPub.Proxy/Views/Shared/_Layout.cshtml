<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin.css">
    <script src="~/js/htmx.min.js"></script>
    <script src="~/js/admin.js" defer></script>

</head>
<body class="@ViewData["BodyClass"]">
@if (User.Identity?.IsAuthenticated == true && ViewData["BodyClass"] as string != "login")
{
<nav class="admin-nav">
    <a href="/admin/logs" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Logs" ? "active" : "")">Логи</a>
    <a href="/admin/playback-errors" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "PlaybackErrors" ? "active" : "")">Ошибки CDN</a>
    <a href="/admin/vip" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Vip" ? "active" : "")">VIP</a>
    <a href="/admin/settings" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")">Настройки</a>
    <form asp-controller="Auth" asp-action="Logout" method="post" class="form-inline">
        <button type="submit" class="danger">Выйти</button>
    </form>
</nav>
}
@RenderBody()
<div id="conn-error" class="conn-error hidden">Сервер недоступен</div>
</body>
</html>
