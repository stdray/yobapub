@model LogsViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "YobaPub Logs";
    var q = Model.Query;
    var pageSize = Math.Clamp(q.PageSize > 0 ? q.PageSize : 100, 1, 500);
    var levelParts = (q.Level ?? []).Where(l => !string.IsNullOrEmpty(l)).Select(l => $"level={Uri.EscapeDataString(l)}");
    var filterQs = string.Join("&", levelParts.Concat(new[] {
        $"device={Uri.EscapeDataString(q.Device ?? "")}",
        $"traceId={Uri.EscapeDataString(q.TraceId ?? "")}",
        $"search={Uri.EscapeDataString(q.Search ?? "")}"
    }));
    var currentQs = $"{filterQs}&pageSize={pageSize}";
    var levelJson = Html.Raw(JsonSerializer.Serialize(q.Level ?? []));
}
<div id="page-content">
<header>
  <h1>YobaPub Logs</h1>
  <form id="log-filter-form"
        hx-get="/admin/logs"
        hx-target="#page-content"
        hx-select="#page-content"
        hx-swap="outerHTML"
        hx-push-url="true"
        hx-trigger="change"
        style="display:contents">
    <select name="level" id="level-select" multiple style="display:none">
      @foreach (var lvl in new[] { "Error", "Warning", "Information", "Verbose" })
      {
        <option value="@lvl" selected="@((q.Level ?? []).Contains(lvl) ? "selected" : null)">@lvl</option>
      }
    </select>
    <input type="hidden" name="device" value="@q.Device">
    <input type="text" name="search" value="@q.Search" placeholder="Поиск..."
           style="width:160px" hx-trigger="change, keyup[key=='Enter']">
    <input type="hidden" name="traceId" value="@q.TraceId">
    <select name="pageSize">
      @foreach (var ps in new[] { 50, 100, 200, 500 })
      {
        <option value="@ps" selected="@(pageSize == ps ? "selected" : null)">@ps / стр.</option>
      }
    </select>
    @if (!string.IsNullOrEmpty(q.TraceId))
    {
      <span class="active-filter">trace: @q.TraceId
        <a href="@Url.Action("Index", new { device = q.Device, search = q.Search, pageSize })"
           title="Сбросить фильтр по trace">&#x2715;</a>
      </span>
    }
  </form>
  <label><input type="checkbox" id="autoRefresh" checked hx-preserve="true"> Auto 10s</label>
  <span id="status"></span>
  <div class="dropdown" x-data="{ open: false }">
    <button type="button" class="dropdown-toggle" @@click="open = !open">Выгрузить &#x25BE;</button>
    <div class="dropdown-menu" x-show="open" @@click.outside="open=false" @@click="open=false">
      <a href="/admin/logs/download?@(filterQs)&limit=15">Последние 15</a>
      <a href="/admin/logs/download?@(filterQs)&limit=50">Последние 50</a>
      <a href="/admin/logs/download?@(filterQs)">Загрузить все</a>
    </div>
  </div>
  <div class="dropdown" x-data="{ open: false }">
    <button type="button" class="dropdown-toggle" @@click="open = !open">Копировать &#x25BE;</button>
    <div class="dropdown-menu" x-show="open" @@click.outside="open=false">
      <a href="#" @@click.prevent="copyLogs(15); open=false">Последние 15</a>
      <a href="#" @@click.prevent="copyLogs(50); open=false">Последние 50</a>
      <a href="#" @@click.prevent="copyLogs(0); open=false">Копировать все</a>
    </div>
  </div>
  <form hx-post="/admin/logs/clear"
        hx-target="#page-content"
        hx-select="#page-content"
        hx-swap="outerHTML"
        hx-confirm="Удалить все логи?"
        style="margin:0">
    @foreach (var lvl in q.Level ?? [])
    {
      <input type="hidden" name="level" value="@lvl">
    }
    <input type="hidden" name="device" value="@q.Device">
    <input type="hidden" name="traceId" value="@q.TraceId">
    <input type="hidden" name="search" value="@q.Search">
    <input type="hidden" name="pageSize" value="@pageSize">
    <button type="submit" class="danger">Очистить</button>
  </form>
</header>
<table>
  <thead>
    <tr>
      <th class="ts">Time</th>
      <th class="dev">Device</th>
      <th class="trace">Trace</th>
      <th class="ip">IP</th>
      <th class="lvl"
          x-data="{
            open: false,
            levels: ['Error','Warning','Information','Verbose'],
            selected: @levelJson,
            apply() {
              var sel = document.getElementById('level-select');
              Array.from(sel.options).forEach(function(o) { o.selected = this.selected.includes(o.value); }, this);
              sel.dispatchEvent(new Event('change', { bubbles: true }));
              this.open = false;
            }
          }"
          style="cursor:pointer;user-select:none">
        <span @@click="open = !open" :style="selected.length ? 'color:#6af' : ''">Lvl</span>
        <div x-show="open" @@click.outside="apply()"
             style="position:absolute;top:100%;left:0;background:#222;border:1px solid #444;padding:4px 0;z-index:50;white-space:nowrap;font-weight:normal;min-width:130px">
          <template x-for="lvl in levels" :key="lvl">
            <label style="display:flex;align-items:center;gap:6px;padding:4px 10px;cursor:pointer">
              <input type="checkbox" :value="lvl" x-model="selected">
              <span x-text="lvl" style="font-size:12px"></span>
            </label>
          </template>
        </div>
      </th>
      <th class="cat">Category</th>
      <th class="msg">Message</th>
      <th class="act"></th>
    </tr>
  </thead>
  <tbody>
    <tr id="top-sentinel"
        hx-get="/admin/logs/more?@currentQs&after=@Model.TopId"
        hx-trigger="every 10s [document.getElementById('autoRefresh').checked]"
        hx-swap="outerHTML"
        hx-target="this"
        style="display:none">
    </tr>
    @if (Model.Entries.Length == 0)
    {
      <tr id="empty-row"><td colspan="8" class="empty">Записей нет</td></tr>
    }
    @await Html.PartialAsync("_Rows", Model)
  </tbody>
</table>
</div>
<script>
var copyToClipboard = function(text) {
  if (navigator.clipboard) { navigator.clipboard.writeText(text); return; }
  var ta = document.createElement('textarea');
  ta.value = text; document.body.appendChild(ta); ta.select();
  document.execCommand('copy'); document.body.removeChild(ta);
};
var copyLogs = function(limit) {
  var url = '/admin/logs/tsv?@Html.Raw(filterQs)' + (limit ? '&limit=' + limit : '');
  fetch(url).then(function(r) { return r.text(); }).then(function(text) {
    copyToClipboard(text);
    var s = document.getElementById('status');
    var prev = s.textContent;
    s.textContent = 'Скопировано!';
    setTimeout(function() { s.textContent = prev; }, 2000);
  });
};
</script>
