@model LogsViewModel
@{
    ViewData["Title"] = "YobaPub Logs";
    var q = Model.Query;
    var pageSize = Math.Clamp(q.PageSize > 0 ? q.PageSize : 100, 1, 500);
    var filterQs = $"level={Uri.EscapeDataString(q.Level ?? "")}&device={Uri.EscapeDataString(q.Device ?? "")}&traceId={Uri.EscapeDataString(q.TraceId ?? "")}&search={Uri.EscapeDataString(q.Search ?? "")}";
    var currentQs = $"{filterQs}&pageSize={pageSize}";
}
<div id="page-content">
<header>
  <h1>YobaPub Logs</h1>
  <form hx-get="/admin/logs"
        hx-target="#page-content"
        hx-select="#page-content"
        hx-swap="outerHTML"
        hx-push-url="true"
        hx-trigger="change"
        style="display:contents">
    <select name="level">
      <option value="">Все уровни</option>
      @foreach (var lvl in new[] { "Error", "Warning", "Information", "Verbose" })
      {
        <option value="@lvl" selected="@(q.Level == lvl ? "selected" : null)">@lvl</option>
      }
    </select>
    <input type="text" name="device" value="@q.Device" placeholder="Device prefix..."
           style="width:120px" hx-trigger="change, keyup[key=='Enter']">
    <input type="text" name="search" value="@q.Search" placeholder="Поиск..."
           style="width:160px" hx-trigger="change, keyup[key=='Enter']">
    <input type="hidden" name="traceId" value="@q.TraceId">
    <select name="pageSize">
      @foreach (var ps in new[] { 50, 100, 200, 500 })
      {
        <option value="@ps" selected="@(pageSize == ps ? "selected" : null)">@ps / стр.</option>
      }
    </select>
    @if (!string.IsNullOrEmpty(q.TraceId))
    {
      <span class="active-filter">trace: @q.TraceId
        <a href="@Url.Action("Index", new { level = q.Level, device = q.Device, search = q.Search, pageSize })"
           title="Сбросить фильтр по trace">&#x2715;</a>
      </span>
    }
  </form>
  <label><input type="checkbox" id="autoRefresh" checked hx-preserve="true"> Auto 10s</label>
  <span id="status"></span>
  <div class="dropdown">
    <button type="button" class="dropdown-toggle">Выгрузить &#x25BE;</button>
    <div class="dropdown-menu">
      <a href="/admin/logs/download?@(filterQs)&limit=15">Последние 15</a>
      <a href="/admin/logs/download?@(filterQs)&limit=50">Последние 50</a>
      <a href="/admin/logs/download?@(filterQs)">Загрузить все</a>
    </div>
  </div>
  <div class="dropdown">
    <button type="button" class="dropdown-toggle">Копировать &#x25BE;</button>
    <div class="dropdown-menu">
      <a href="#" onclick="copyLogs(15);return false">Последние 15</a>
      <a href="#" onclick="copyLogs(50);return false">Последние 50</a>
      <a href="#" onclick="copyLogs(0);return false">Копировать все</a>
    </div>
  </div>
  <form hx-post="/admin/logs/clear"
        hx-target="#page-content"
        hx-select="#page-content"
        hx-swap="outerHTML"
        hx-confirm="Удалить все логи?"
        style="margin:0">
    <input type="hidden" name="level" value="@q.Level">
    <input type="hidden" name="device" value="@q.Device">
    <input type="hidden" name="traceId" value="@q.TraceId">
    <input type="hidden" name="search" value="@q.Search">
    <input type="hidden" name="pageSize" value="@pageSize">
    <button type="submit" class="danger">Очистить</button>
  </form>
</header>
<table>
  <thead>
    <tr>
      <th class="ts">Time</th>
      <th class="dev">Device</th>
      <th class="trace">Trace</th>
      <th class="ip">IP</th>
      <th class="lvl">L</th>
      <th class="cat">Category</th>
      <th class="msg">Message</th>
      <th class="act"></th>
    </tr>
  </thead>
  <tbody>
    <tr id="top-sentinel"
        hx-get="/admin/logs/more?@filterQs&pageSize=@pageSize&after=@Model.TopId"
        hx-trigger="every 10s [document.getElementById('autoRefresh').checked]"
        hx-swap="outerHTML"
        hx-target="this"
        style="display:none">
    </tr>
    @if (Model.Entries.Length == 0)
    {
      <tr id="empty-row"><td colspan="8" class="empty">Записей нет</td></tr>
    }
    @await Html.PartialAsync("_Rows", Model)
  </tbody>
</table>
</div>
<script>
document.addEventListener('click', function(e) {
  var open = document.querySelector('.dropdown.open');
  if (open && !open.contains(e.target)) open.classList.remove('open');
});
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.dropdown-toggle');
  if (!btn) return;
  e.stopPropagation();
  var dd = btn.parentElement;
  var wasOpen = dd.classList.contains('open');
  var prev = document.querySelector('.dropdown.open');
  if (prev) prev.classList.remove('open');
  if (!wasOpen) dd.classList.add('open');
});
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.copy-row-btn');
  if (!btn) return;
  var id = btn.getAttribute('data-id');
  fetch('/admin/logs/' + id + '/text').then(function(r) { return r.text(); }).then(function(text) {
    copyToClipboard(text);
    btn.textContent = '\u2713';
    setTimeout(function() { btn.innerHTML = '\u2398'; }, 1500);
  });
});
var copyToClipboard = function(text) {
  if (navigator.clipboard) { navigator.clipboard.writeText(text); return; }
  var ta = document.createElement('textarea');
  ta.value = text;
  document.body.appendChild(ta);
  ta.select();
  document.execCommand('copy');
  document.body.removeChild(ta);
};
var copyLogs = function(limit) {
  var url = '/admin/logs/tsv?@Html.Raw(filterQs)' + (limit ? '&limit=' + limit : '');
  fetch(url).then(function(r) { return r.text(); }).then(function(text) {
    copyToClipboard(text);
    var s = document.getElementById('status');
    var prev = s.textContent;
    s.textContent = 'Скопировано!';
    setTimeout(function() { s.textContent = prev; }, 2000);
  });
  var open = document.querySelector('.dropdown.open');
  if (open) open.classList.remove('open');
};
</script>
