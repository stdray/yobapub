@model LogsViewModel
@{
    ViewData["Title"] = "YobaPub Logs";
    var tz = UserSettingsStore.Get(User.Identity!.Name!).TimeZoneOffset;
}
<div id="page-content"
     x-data="logsPage()"
     x-init="boot()"
     data-top-id="@Model.TopId"
     data-last-id="@Model.LastId">
<header>
  <form class="filter-form" @@submit.prevent="doSearch()">
    <input type="text" x-model="search" placeholder="Поиск..." class="search-input"
           @@keydown.enter.prevent="doSearch()">
    <select x-model.number="pageSize" @@change="doSearch()">
      @foreach (var ps in new[] { 50, 100, 200, 500 })
      {
        <option value="@ps">@ps / стр.</option>
      }
    </select>
    <button type="submit">Найти</button>
    <button type="button" @@click="reset()">Сброс</button>
  </form>
  <div class="filter-fields">
    @foreach (var field in new[] { "Level", "Category", "DeviceId", "TraceId", "ClientIp" })
    {
      <div class="filter-field" x-data="{ val: '' }">
        <label>@field</label>
        <input type="text" x-model="val" placeholder="значение"
               @@keydown.enter.prevent="if (val) { $store.logs.addIncl('@field', val); val = ''; }">
        <button type="button" class="filter-field__inc" title="Добавить в include"
                @@click="if (val) { $store.logs.addIncl('@field', val); val = ''; }">&#x2713;</button>
        <button type="button" class="filter-field__exc" title="Добавить в exclude"
                @@click="if (val) { $store.logs.addExcl('@field', val); val = ''; }">&#x2715;</button>
        <template x-for="chip in fieldChips('@field')" :key="chip.key">
          <span class="active-filter" :class="chip.mode">
            <span x-text="chip.mode === 'inc' ? '=' : '≠'"></span>
            <span x-text="chip.value"></span>
            <a href="#" @@click.prevent="removeFilter('@field', chip.mode, chip.value)">&#x2715;</a>
          </span>
        </template>
      </div>
    }
  </div>
  <label><input type="checkbox" x-model="autoRefresh"> Auto 10s</label>
  <span id="status" x-text="status"></span>
  <div class="dropdown">
    <button type="button" class="dropdown-toggle">Выгрузить &#x25BE;</button>
    <div class="dropdown-menu">
      <a href="#" @@click.prevent="download(15)">Последние 15</a>
      <a href="#" @@click.prevent="download(50)">Последние 50</a>
      <a href="#" @@click.prevent="download(0)">Загрузить все</a>
    </div>
  </div>
  <div class="dropdown">
    <button type="button" class="dropdown-toggle">Копировать &#x25BE;</button>
    <div class="dropdown-menu">
      <a href="#" @@click.prevent="copy(15)">Последние 15</a>
      <a href="#" @@click.prevent="copy(50)">Последние 50</a>
      <a href="#" @@click.prevent="copy(0)">Копировать все</a>
    </div>
  </div>
  <div class="dropdown">
    <button type="button" class="dropdown-toggle">Поделиться &#x25BE;</button>
    <div class="dropdown-menu">
      <a href="#" @@click.prevent="share(1)">На 1 день</a>
      <a href="#" @@click.prevent="share(7)">На 7 дней</a>
      <a href="#" @@click.prevent="share(30)">На 30 дней</a>
      <a href="#" @@click.prevent="share(0)">Без срока</a>
    </div>
  </div>
  <button type="button" class="danger"
          @@click="if (confirm('Удалить все логи?')) clearLogs()">Очистить</button>
</header>
<table>
  <thead>
    <tr>
      <th class="ts">Time</th>
      <th class="dev">Device</th>
      <th class="trace">Trace</th>
      <th class="ip">IP</th>
      <th class="lvl">Lvl</th>
      <th class="cat">Category</th>
      <th class="msg">Message</th>
      <th class="act"></th>
    </tr>
  </thead>
  <tbody id="logs-tbody">
    @await Html.PartialAsync("_Rows", Model)
  </tbody>
</table>
<div class="load-more-wrap" x-show="hasMore" x-ref="loadMoreEl">
  <button type="button" @@click="loadMore()" :disabled="loading">Загрузить ещё</button>
</div>
</div>
