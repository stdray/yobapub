@model LogsViewModel
@{
    var q = Model.Query;
    var pageSize = Math.Clamp(q.PageSize > 0 ? q.PageSize : 100, 1, 500);
    var levelParts = (q.Level ?? []).Where(l => !string.IsNullOrEmpty(l)).Select(l => $"level={Uri.EscapeDataString(l)}");
    var filterQs = string.Join("&", levelParts.Concat(new[] {
        $"device={Uri.EscapeDataString(q.Device ?? "")}",
        $"traceId={Uri.EscapeDataString(q.TraceId ?? "")}",
        $"search={Uri.EscapeDataString(q.Search ?? "")}"
    }));
    var isRefresh = q.After != null;
    var rowClass  = isRefresh ? "row-new" : q.Before != null ? "row-old" : "";
}
@if (isRefresh && Model.Entries.Length > 0)
{
    <tr id="empty-row" style="display:none" hx-swap-oob="outerHTML"></tr>
}
@foreach (var e in Model.Entries)
{
    var cls = e.Level switch { "Error" => "E", "Warning" => "W", "Verbose" => "V", _ => "" };
    var devPrefix = e.DeviceId.Length >= 8 ? e.DeviceId[..8] : e.DeviceId;
    <tr class="@cls @rowClass">
        <td class="ts"><a href="/admin/logs/@e.Id">@e.ServerTs.FormatTime(UserSettingsStore.Get(User.Identity!.Name!).TimeZoneOffset)</a></td>
        <td class="dev" title="@e.DeviceId">@devPrefix</td>
        <td class="trace">
            @if (!string.IsNullOrEmpty(e.TraceId))
            {
                <a class="trace-btn" href="@Url.Action("Index", new { level = q.Level, device = devPrefix, search = q.Search, traceId = e.TraceId, pageSize })"
                   title="Фильтр по device + trace">@e.TraceId</a>
            }
        </td>
        <td class="ip">@e.ClientIp</td>
        <td class="lvl lvl-@e.Level">@e.Level.LevelAbbr()</td>
        @{ var cat = e.Category ?? ""; }
        <td class="cat" title="@cat">@cat.ShortName()</td>
        <td class="msg">@e.Message</td>
        <td class="act" x-data="{ done: false }">
            <button class="copy-row-btn" type="button" title="Копировать"
                    x-text="done ? '\u2713' : '\u2398'"
                    @@click="fetch('/admin/logs/@e.Id/text').then(r=>r.text()).then(t=>{copyToClipboard(t);done=true;setTimeout(()=>done=false,1500)})">
            </button>
        </td>
    </tr>
}
@if (isRefresh)
{
    <tr id="top-sentinel"
        hx-get="/admin/logs/more?@filterQs&pageSize=@pageSize&after=@Model.TopId"
        hx-trigger="every 10s [document.getElementById('autoRefresh').checked]"
        hx-swap="outerHTML"
        hx-target="this"
        style="display:none">
    </tr>
}
else if (Model.HasMore && Model.LastId != null)
{
    <tr hx-get="/admin/logs/more?@filterQs&pageSize=@pageSize&before=@Model.LastId"
        hx-trigger="intersect once"
        hx-swap="outerHTML"
        hx-target="this">
        <td colspan="8" style="text-align:center;color:#555;padding:6px">↓</td>
    </tr>
}
