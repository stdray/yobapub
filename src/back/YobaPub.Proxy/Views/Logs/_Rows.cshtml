@model LogsViewModel
@{
    var q = Model.Query;
    var tz = UserSettingsStore.Get(User.Identity!.Name!).TimeZoneOffset;
}
@functions {
    Microsoft.AspNetCore.Html.IHtmlContent Cell(string field, string value, string? display = null)
    {
        if (string.IsNullOrEmpty(value))
            return Microsoft.AspNetCore.Html.HtmlString.Empty;
        var text = display ?? value;
        var safeValue = System.Text.Encodings.Web.HtmlEncoder.Default.Encode(value);
        var safeText = System.Text.Encodings.Web.HtmlEncoder.Default.Encode(text);
        return new Microsoft.AspNetCore.Html.HtmlString(
            $"<span class=\"cell\">{safeText}" +
            $"<a class=\"cell__inc\" href=\"#\" @click.prevent=\"$store.logs.addIncl('{field}', '{safeValue}')\">&#x2713;</a>" +
            $"<a class=\"cell__exc\" href=\"#\" @click.prevent=\"$store.logs.addExcl('{field}', '{safeValue}')\">&#x2715;</a>" +
            $"</span>");
    }
}
<tr data-top-id="@Model.TopId" data-last-id="@Model.LastId" data-has-more="@(Model.HasMore ? "1" : "0")" class="hidden"></tr>
@if (Model.Entries.Length == 0)
{
    <tr><td colspan="8" class="empty">Записей нет</td></tr>
}
@foreach (var e in Model.Entries)
{
    var cls = e.Level switch { "Error" => "E", "Warning" => "W", "Verbose" => "V", _ => "" };
    var devPrefix = e.DeviceId.Length >= 8 ? e.DeviceId[..8] : e.DeviceId;
    var cat = e.Category ?? "";
    <tr class="@cls">
        <td class="ts"><a href="/admin/logs/@e.Id">@e.ServerTs.FormatTime(tz)</a></td>
        <td class="dev" title="@e.DeviceId">@Cell("DeviceId", e.DeviceId, devPrefix)</td>
        <td class="trace">@Cell("TraceId", e.TraceId)</td>
        <td class="ip">@Cell("ClientIp", e.ClientIp)</td>
        <td class="lvl lvl-@e.Level">@Cell("Level", e.Level, e.Level.LevelAbbr())</td>
        <td class="cat" title="@cat">@Cell("Category", cat, cat.ShortName())</td>
        <td class="msg">@e.Message</td>
        <td class="act">
            <button class="copy-row-btn" type="button" title="Копировать"
                    data-copy-url="/admin/logs/@e.Id/text">&#x2398;</button>
        </td>
    </tr>
}
