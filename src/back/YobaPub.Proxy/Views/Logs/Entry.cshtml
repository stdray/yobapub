@model LogEntry
@{
    ViewData["Title"] = "Log Entry";
    var devPrefix = Model.DeviceId.Length >= 8 ? Model.DeviceId[..8] : Model.DeviceId;
    var utcIso = Model.ServerTs.UtcDateTime.ToString("o");
}
<div class="log-detail">
  <div class="log-detail__header">
    <a href="/admin/logs" class="back-link">&#x2190; Логи</a>
    <h1>Событие @Model.Id</h1>
    <button type="button" class="copy-all-btn" onclick="copyEntry()">Копировать</button>
  </div>
  <table class="log-detail__table">
    <tr><th>Time</th><td><span data-utc="@utcIso"></span></td></tr>
    <tr><th>Device</th><td title="@Model.DeviceId">@devPrefix</td></tr>
    @if (!string.IsNullOrEmpty(Model.TraceId))
    {
      <tr><th>TraceId</th><td>@Model.TraceId</td></tr>
    }
    <tr><th>IP</th><td>@Model.ClientIp</td></tr>
    <tr><th>Level</th><td>@Model.Level</td></tr>
    <tr><th>Category</th><td>@Model.Category</td></tr>
    <tr><th>Message</th><td class="msg">@Model.Message</td></tr>
    @if (!string.IsNullOrEmpty(Model.Props) && Model.Props != "{}")
    {
      <tr><th>Props</th><td><pre class="log-detail__pre">@Model.Props</pre></td></tr>
    }
    @if (!string.IsNullOrEmpty(Model.StackTrace))
    {
      <tr><th>StackTrace</th><td><pre class="log-detail__pre log-detail__stack">@Model.StackTrace</pre></td></tr>
    }
  </table>
</div>
<script>
function pad(n) { return n < 10 ? '0'+n : ''+n; }
function fmtFull(iso) { var d = new Date(iso); return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate())+' '+pad(d.getHours())+':'+pad(d.getMinutes())+':'+pad(d.getSeconds()); }
document.querySelectorAll('[data-utc]').forEach(function(el) { el.textContent = fmtFull(el.getAttribute('data-utc')); });
function copyEntry() {
  fetch('/admin/logs/@Model.Id/text').then(function(r) { return r.text(); }).then(function(text) {
    if (navigator.clipboard) { navigator.clipboard.writeText(text); }
    else {
      var ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta); ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }
    var btn = document.querySelector('.copy-all-btn');
    btn.textContent = 'Скопировано!';
    setTimeout(function() { btn.textContent = 'Копировать'; }, 2000);
  });
}
</script>
