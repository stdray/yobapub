@model LogEntry
@{
    ViewData["Title"] = "Log Entry";
    var devPrefix = Model.DeviceId.Length >= 8 ? Model.DeviceId[..8] : Model.DeviceId;
    var tz = UserSettingsStore.Get(User.Identity!.Name!).TimeZoneOffset;
}
<div class="log-detail" id="entry-data" data-entry-id="@Model.Id">
  <div class="log-detail__header">
    <a href="/admin/logs" class="back-link">&#x2190; Логи</a>
    <h1>Событие @Model.Id</h1>
    <button type="button" class="copy-all-btn">Копировать</button>
  </div>
  <table class="log-detail__table">
    <tr><th>Time</th><td>@Model.ServerTs.FormatFull(tz)</td></tr>
    <tr><th>Device</th><td title="@Model.DeviceId">@devPrefix</td></tr>
    @if (!string.IsNullOrEmpty(Model.TraceId))
    {
      <tr><th>TraceId</th><td>@Model.TraceId</td></tr>
    }
    <tr><th>IP</th><td>@Model.ClientIp</td></tr>
    <tr><th>Level</th><td>@Model.Level</td></tr>
    <tr><th>Category</th><td>@Model.Category</td></tr>
    <tr><th>Message</th><td class="msg">@Model.Message</td></tr>
    @if (!string.IsNullOrEmpty(Model.Props) && Model.Props != "{}")
    {
      <tr><th>Props</th><td><pre class="log-detail__pre">@Model.Props</pre></td></tr>
    }
    @if (!string.IsNullOrEmpty(Model.StackTrace))
    {
      <tr><th>StackTrace</th><td><pre class="log-detail__pre log-detail__stack">@Model.StackTrace</pre></td></tr>
    }
  </table>
</div>
