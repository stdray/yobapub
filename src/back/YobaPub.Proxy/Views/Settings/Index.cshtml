@model SettingsViewModel
@{
    ViewData["Title"] = "YobaPub - Настройки";
}
<header>
  <h1>Настройки</h1>
</header>
<div id="page-content" class="page-pad">
  <table>
    <thead>
      <tr>
        <th>Параметр</th>
        <th>Состояние</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Отладка (запись событий от фронта)</td>
        <td>
          @if (Model.DebugEnabled)
          {
            <span class="status-on">Включена</span>
          }
          else
          {
            <span class="status-off">Выключена</span>
          }
        </td>
        <td>
          <form class="form-inline"
                hx-post="/admin/settings/debug"
                hx-target="#page-content"
                hx-select="#page-content"
                hx-swap="outerHTML">
            <button type="submit">@(Model.DebugEnabled ? "Выключить" : "Включить")</button>
          </form>
        </td>
      </tr>
      <tr>
        <td>Макс. записей в логе</td>
        <td>@Model.MaxLogEntries</td>
        <td>
          <form class="form-row"
                hx-post="/admin/settings/max-log-entries"
                hx-target="#page-content"
                hx-select="#page-content"
                hx-swap="outerHTML">
            <input type="number" name="max" value="@Model.MaxLogEntries" min="100" step="100"
                   class="settings-input-sm">
            <button type="submit">Сохранить</button>
          </form>
        </td>
      </tr>
      <tr>
        <td>Часовой пояс</td>
        <td>UTC@(Model.UserSettings.TimeZoneOffsetHours >= 0 ? "+" : "")@Model.UserSettings.TimeZoneOffsetHours</td>
        <td>
          <form class="form-row"
                hx-post="/admin/settings/timezone"
                hx-target="#page-content"
                hx-select="#page-content"
                hx-swap="outerHTML">
            <input type="number" name="offset" value="@Model.UserSettings.TimeZoneOffsetHours"
                   min="-12" max="14" step="0.5" class="settings-input-xs">
            <button type="submit">Сохранить</button>
          </form>
        </td>
      </tr>
    </tbody>
  </table>
</div>
