@model SettingsViewModel
@{
    ViewData["Title"] = "YobaPub - Настройки";
}
<header>
  <h1>Настройки</h1>
</header>
<div id="page-content" style="padding:16px">
  <table>
    <thead>
      <tr>
        <th>Параметр</th>
        <th>Состояние</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Отладка (запись событий от фронта)</td>
        <td>
          @if (Model.DebugEnabled)
          {
            <span style="color:#2ecc71">Включена</span>
          }
          else
          {
            <span style="color:#e74c3c">Выключена</span>
          }
        </td>
        <td>
          <form hx-post="/admin/settings/debug"
                hx-target="#page-content"
                hx-select="#page-content"
                hx-swap="outerHTML"
                style="margin:0">
            <button type="submit">@(Model.DebugEnabled ? "Выключить" : "Включить")</button>
          </form>
        </td>
      </tr>
      <tr>
        <td>Часовой пояс</td>
        <td>UTC@(Model.UserSettings.TimeZoneOffsetHours >= 0 ? "+" : "")@Model.UserSettings.TimeZoneOffsetHours</td>
        <td>
          <form hx-post="/admin/settings/timezone"
                hx-target="#page-content"
                hx-select="#page-content"
                hx-swap="outerHTML"
                style="margin:0;display:flex;gap:4px">
            <input type="number" name="offset" value="@Model.UserSettings.TimeZoneOffsetHours"
                   min="-12" max="14" step="0.5" style="width:70px">
            <button type="submit">Сохранить</button>
          </form>
        </td>
      </tr>
    </tbody>
  </table>
</div>
