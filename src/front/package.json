{
  "name": "yobapub",
  "version": "1.0.0",
  "description": "Клиент KinoPub для телевизоров Samsung (Tizen 2.3 / 3.0).",
  "main": "dist/app.js",
  "scripts": {
    "patch-hls": "node scripts/patch-hls.js",
    "predev": "npm run patch-hls",
    "prebuild:dev": "npm run patch-hls",
    "prebuild:release": "npm run patch-hls",
    "dev": "webpack serve --mode development",
    "build:dev": "webpack --mode development",
    "build:release": "webpack --mode production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ts/",
    "csslint": "doiuse --browsers \"Chrome >= 28\" --ignore css-overflow,object-fit,css-letter-spacing,word-break,css-nesting css/app.css",
    "escheck": "es-check es5 dist/release/app.*.js",
    "release": "npm run typecheck && npm run lint && npm run csslint && npm run build:release && npm run escheck"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "browserslist": [
    "Chrome >= 28"
  ],
  "dependencies": {
    "core-js": "^3.49.0",
    "dot": "^1.1.3",
    "hls.js": "^0.14.17",
    "jquery": "^2.2.4",
    "object-fit-images": "^3.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.18",
    "@types/hls.js": "^0.13.3",
    "@types/jquery": "^4.0.0",
    "@types/tizen-common-web": "^2.0.6",
    "@types/tizen-tv-webapis": "^2.0.9",
    "autoprefixer": "^10.4.27",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "doiuse": "^6.0.6",
    "es-check": "^9.6.4",
    "eslint": "^10.2.0",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-es-x": "^9.6.0",
    "html-webpack-plugin": "^5.6.6",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.2.1",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
